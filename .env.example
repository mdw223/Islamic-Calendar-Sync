#############################################
# Core app runtime
#############################################
NODE_ENV=development
API_PORT=3000
APP_BASE_URL=http://localhost:5000
SUBSCRIPTION_URL=http://localhost:5000
API_SECRET=replace-with-random-secret # API_SECRET (64 hex chars) openssl rand -hex 32
RATE_LIMIT_MAX=100
CORS_ALLOWED_ORIGINS=http://localhost:5000

#############################################
# JWT / auth
#############################################
JWT_SECRET=replace-with-strong-random-jwt-secret # JWT_SECRET (64 hex chars) openssl rand -hex 32
JWT_EXPIRY_DAYS=7
JWT_ALGORITHM=HS256
SESSION_SECRET=replace-with-session-secret # SESSION_SECRET (64 hex chars) openssl rand -hex 32

#############################################
# Database (PostgreSQL)
#############################################
DB_HOST=database
DB_PORT=5432
POSTGRES_DB=ics_dev
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=change_me # PostgreSQL password (base64, ~43 chars) openssl rand -base64 32
DB_LOG_QUERIES=false

#############################################
# Redis
#############################################
REDIS_HOST=redis
REDIS_PORT=6379

#############################################
# Logging
#############################################
LOG_LEVEL=info

#############################################
# OAuth providers (optional)
#############################################
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/redirect

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=
MICROSOFT_TENANT=
MICROSOFT_SCOPE=

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_CALLBACK_URL=
APPLE_PRIVATE_KEY=
APPLE_PRIVATE_KEY_LOCATION=
APPLE_SCOPE=

#############################################
# Subscription settings
#############################################
SUBSCRIPTION_DEFAULT_RANGE_YEARS=2
SUBSCRIPTION_MAX_ACTIVE_URLS=5

#############################################
# SMTP / email provider
#############################################
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

#############################################
# Contact form
#############################################
CONTACT_TO_EMAIL=
CONTACT_DAILY_LIMIT_PER_EMAIL=1
CONTACT_IP_RATE_LIMIT_MAX=5

#############################################
# Deployment / proxy
#############################################
API_DOMAIN=api.yourdomain.com
